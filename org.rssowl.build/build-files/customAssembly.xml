<project name="RSSOwl custom assembly" default="noop">
	<target name="gather.bin.parts"/>

	<target name="post.gather.bin.parts"/>

	<target name="post.jarUp"/>

	<target name="pre.archive">
		<condition property="is.win64.package">
			<and>
				<equals arg1="${os}" arg2="win32"/>
				<equals arg1="${ws}" arg2="win32"/>
				<equals arg1="${arch}" arg2="x86_64"/>
			</and>
		</condition>
		<antcall target="-bundle.win64.runtime"/>
	</target>

	<target name="-bundle.win64.runtime" if="is.win64.package">
		<available file="${java.home}/bin/javaw.exe" property="bundled.jre.exists"/>
		<fail unless="bundled.jre.exists" message="Expected a Java runtime with javaw.exe under ${java.home}"/>

		<echo message="Bundling Java runtime from ${java.home} into ${rootFolder}/jre"/>
		<mkdir dir="${rootFolder}/jre"/>
		<copy todir="${rootFolder}/jre" overwrite="true">
			<fileset dir="${java.home}">
				<include name="**/*"/>
			</fileset>
		</copy>

		<copy file="${buildHome}/build-files/rootfiles/win32.win32.x86_64/RSSOwl.ini"
		      tofile="${rootFolder}/RSSOwl.ini"
		      overwrite="true"/>
	</target>

	<target name="noop"/>
</project>
